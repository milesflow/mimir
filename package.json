{
  "name": "mimir",
  "version": "0.1.0",
  "description": "CLI that turns AI-assisted coding into durable knowledge (study-driven development)",
  "type": "module",
  "bin": {
    "mimir": "./dist/cli.js",
    "mimir-mcp": "./dist/mcp-server.js"
  },
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx src/cli.ts",
    "dev:mcp": "node --import tsx src/mcp-server.ts",
    "start": "node dist/cli.js",
    "test": "node --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "learning",
    "openspec",
    "study",
    "notes"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^13.1.0",
    "zod": "^4.3.6"
  }
}
